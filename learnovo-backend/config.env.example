# Learnovo Backend Configuration
# Copy this file to config.env and update with your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/learnovo
MONGODB_TEST_URI=mongodb://localhost:27017/learnovo_test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7
SUPER_ADMIN_JWT_SECRET=your-super-admin-jwt-secret-change-this

# Email Configuration (supports both EMAIL_* and SMTP_*)
# For production (Render/Vercel), use EMAIL_* variables
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@learnovo.com

# Legacy SMTP variables (also supported)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@learnovo.com

# Frontend — CORS allowed origins (comma-separated, no trailing slash)
# Used by server.js for the CORS allowlist.
# Production: FRONTEND_ORIGIN=https://learnovoapp.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Frontend base URL used in email links (password-reset, invitations)
# Production: FRONTEND_URL=https://learnovoapp.vercel.app
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Rate Limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Monitoring and Analytics
ENABLE_METRICS=true
METRICS_PORT=9090

# Razorpay Payment Gateway (Fee Payments)
# Get these from https://dashboard.razorpay.com → Settings → API Keys
# Test keys start with rzp_test_, live keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret: set this in Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ICICI Orange Callback (HTTP Basic Auth credentials)
# These are the credentials YOU define and hand to ICICI during onboarding.
# ICICI's server uses them in the Authorization header when POSTing to:
#   POST /api/fee-payments/webhook/icici-orange/<tenantCode>
# Per-tenant — only the SPIS production tenant is currently provisioned.
# Production values live ONLY on the VPS, never committed.
ICICI_ORANGE_SPIS_CALLBACK_USER=spis_learnovo_prod
ICICI_ORANGE_SPIS_CALLBACK_PASS=replace_with_strong_random_secret

# Backend public URL (used for payment gateway return URLs)
# Production: BACKEND_URL=https://api.learnovoportal.com
BACKEND_URL=http://localhost:5001

# Cloudinary (photo & document storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# External Services (Optional)
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 Configuration (Document Storage)
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=learnovo-files
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Field-Level Encryption (AES-256-GCM) for sensitive payment data
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes / 256-bit)
ENCRYPTION_KEY=your_64_hex_char_encryption_key_generate_with_command_above

# Development Tools
ENABLE_DEBUG=false
ENABLE_SWAGGER=true
